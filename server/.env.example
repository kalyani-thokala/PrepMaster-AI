PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/prepmaster-ai

# JWT Authentication
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here_make_it_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_make_it_long_and_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Mailer Configurations (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@prepmasterai.com

# CORS Configuration
CLIENT_URL=http://localhost:5173
