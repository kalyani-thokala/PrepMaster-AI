# ==============================================================================
# PrepMaster AI Backend Environment Variables Template
# ==============================================================================

# Core Application Settings
NODE_ENV=development                       # Execution environment (development, production, test)
PORT=5000                                  # Network port for Express server to bind to

# MongoDB Connection String
# For Local Development: mongodb://127.0.0.1:27017/prepmaster-ai
# For Production/Render: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb://localhost:27017/prepmaster-ai

# JWT Security Secrets (Use long, cryptographically strong random strings in production)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here_make_it_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_make_it_long_and_secure
JWT_ACCESS_EXPIRY=15m                      # Expiration time for access token (e.g. 15m, 1h)
JWT_REFRESH_EXPIRY=7d                      # Expiration time for refresh token (e.g. 7d, 30d)

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Mailer Configurations (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@prepmasterai.com

# CORS Configuration (Comma-separated origins allowed to make requests)
CLIENT_URL=http://localhost:5173
