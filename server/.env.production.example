# ==============================================================================
# PrepMaster AI Backend - Production Environment Variables Template (Render)
# ==============================================================================

# Core Application Settings
NODE_ENV=production
PORT=10000                                 # Render default port is handled automatically, but 10000 is default

# MongoDB Connection String (MUST be MongoDB Atlas URI. Localhost is rejected)
# Format: mongodb+srv://<db_user>:<db_password>@<cluster_domain>.mongodb.net/<database_name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/prepmaster-ai-production?retryWrites=true&w=majority

# JWT Security Secrets (MUST be long, highly secure random strings)
JWT_ACCESS_SECRET=generate_a_secure_64_character_hex_string_for_access_secret_production
JWT_REFRESH_SECRET=generate_a_secure_64_character_hex_string_for_refresh_secret_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google Gemini API Configuration
GEMINI_API_KEY=your_production_google_gemini_api_key

# Mailer Configurations (Nodemailer - use production mail provider like SendGrid/Mailgun)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_production_email_provider_api_key
EMAIL_FROM=no-reply@prepmasterai.com

# CORS Configuration (Comma-separated client origins allowed in production)
CLIENT_URL=https://prepmasterai.onrender.com,https://prepmaster-ai-client.web.app
