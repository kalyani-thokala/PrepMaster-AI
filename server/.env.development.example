# ==============================================================================
# PrepMaster AI Backend - Local Development Environment Variables Template
# ==============================================================================

# Core Application Settings
NODE_ENV=development
PORT=5000

# MongoDB Connection String (Points to local MongoDB instance)
MONGODB_URI=mongodb://127.0.0.1:27017/prepmaster-ai

# JWT Security Secrets (Simple strings for local testing)
JWT_ACCESS_SECRET=local_jwt_access_secret_key_dev_testing_only_123456789
JWT_REFRESH_SECRET=local_jwt_refresh_secret_key_dev_testing_only_123456789
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google Gemini API Configuration
GEMINI_API_KEY=your_development_google_gemini_api_key

# Mailer Configurations (Local Mailer e.g. Mailtrap)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@prepmasterai.com

# CORS Configuration (Local Client Origins)
CLIENT_URL=http://localhost:5173,http://localhost:5174
